# p13_functions/fts — full-text search (P10 F1): to_tsvector / to_tsquery / plainto_tsquery and the
# `@@` match. Two configurations, both byte-exact with PG for plain-word input: `simple` (lowercase
# only) and `english` (Snowball stopwords + Snowball English stemmer; also the default for the
# 1-argument forms, matching PG's stock default_text_search_config). Other configurations, phrase
# `<->`, and weight suffixes are loud errors.

# to_tsvector: canonical form — lexemes sorted, quoted, 1-based ascending positions.
query T
SELECT to_tsvector('simple', 'The quick brown fox')
----
'brown':3 'fox':4 'quick':2 'the':1

# Repeats collect positions on one lexeme; punctuation only separates.
query T
SELECT to_tsvector('simple', 'a b, a. b a')
----
'a':1,3,5 'b':2,4

# Digits are lexemes; case folds.
query T
SELECT to_tsvector('simple', 'Abc123 42')
----
'42':2 'abc123':1

# to_tsquery canonicalizes: parens only where precedence needs them.
query T
SELECT to_tsquery('simple', 'fox & quick')
----
'fox' & 'quick'

query T
SELECT to_tsquery('simple', 'a & (b | c)')
----
'a' & ( 'b' | 'c' )

query T
SELECT to_tsquery('simple', '!(a | b)')
----
!( 'a' | 'b' )

# plainto_tsquery ANDs the lexemes; operators in the input are plain text.
query T
SELECT plainto_tsquery('simple', 'The Fat Rats')
----
'the' & 'fat' & 'rats'

# The @@ match over a table column.
statement ok
CREATE TABLE docs (id INT, body TEXT)

statement ok
INSERT INTO docs VALUES (1, 'The quick brown fox'), (2, 'The lazy dog'), (3, 'A quick dog')

query I
SELECT id FROM docs WHERE to_tsvector('simple', body) @@ to_tsquery('simple', 'quick & fox') ORDER BY id
----
1

query I
SELECT id FROM docs WHERE to_tsvector('simple', body) @@ to_tsquery('simple', 'quick | lazy') ORDER BY id
----
1
2
3

query I
SELECT id FROM docs WHERE to_tsvector('simple', body) @@ to_tsquery('simple', 'dog & !lazy') ORDER BY id
----
3

# The swapped orientation (tsquery @@ tsvector) is accepted, like PG.
query I
SELECT id FROM docs WHERE to_tsquery('simple', 'fox') @@ to_tsvector('simple', body) ORDER BY id
----
1

# NULL propagates through @@ and the functions.
query T
SELECT to_tsvector('simple', NULL) IS NULL
----
1

query T
SELECT (to_tsvector('simple', 'x') @@ NULL) IS NULL
----
1

# The english configuration: Snowball stemming, stopwords dropped but their positions consumed.
# (The canonical example from PG's own documentation.)
query T
SELECT to_tsvector('english', 'a fat  cat sat on a mat - it ate a fat rats')
----
'ate':9 'cat':3 'fat':2,11 'mat':7 'rat':12 'sat':4

query T
SELECT to_tsvector('english', 'The quick brown foxes jumped over the lazy dogs')
----
'brown':3 'dog':9 'fox':4 'jump':5 'lazi':8 'quick':2

# The 1-argument forms default to english, like PG's stock default_text_search_config.
query T
SELECT to_tsvector('The quick brown foxes jumped over the lazy dogs')
----
'brown':3 'dog':9 'fox':4 'jump':5 'lazi':8 'quick':2

query T
SELECT to_tsquery('english', 'The & Fat & Rats')
----
'fat' & 'rat'

# A stopword operand is elided from the boolean structure; an all-stopword query is empty.
query T
SELECT to_tsquery('english', 'fat & !the')
----
'fat'

query T
SELECT plainto_tsquery('The Fat Rats')
----
'fat' & 'rat'

# Stemmed match end-to-end: the query word 'foxes' stems to the lexeme 'fox' in the document.
query I
SELECT id FROM docs WHERE to_tsvector('english', body) @@ to_tsquery('english', 'foxes') ORDER BY id
----
1

# Digit-bearing tokens skip the stopword/stem pipeline (PG's numword class uses simple).
query T
SELECT to_tsvector('english', 'the42 12 the')
----
'12':2 'the42':1

# Honest loud errors: an unknown configuration, phrase search, malformed tsquery.
statement error
SELECT to_tsvector('french', 'foxes')

statement error
SELECT to_tsquery('simple', 'fox <-> quick')

# Malformed tsquery is a syntax error, like PG.
statement error
SELECT to_tsquery('simple', 'fox &')

# --- Relevance ranking: ts_rank / ts_rank_cd ---

# PG's documented single-term score, 0.1 / (pi^2/6) = 0.06079271 (the query type rounds to 3dp;
# the exact float4 text is pinned in the fts unit tests).
query R
SELECT ts_rank(to_tsvector('simple', 'fox'), to_tsquery('simple', 'fox'))
----
0.061

# Two adjacent default-weight terms AND together: sqrt(0.1*0.1*word_distance(1)) = 0.09910322,
# the value measured on PG16 (Q-TSRANK-AND-PROXIMITY).
query R
SELECT ts_rank(to_tsvector('simple', 'a b'), to_tsquery('simple', 'a & b'))
----
0.099

# Cover-density of the same adjacent pair: coverlen / sum(1/weight) = 2/20 = 0.1.
query R
SELECT ts_rank_cd(to_tsvector('simple', 'a b'), to_tsquery('simple', 'a & b'))
----
0.100

# Ranking drives ordering: doc 3 matches both operands, docs 1 and 2 one each (id breaks the tie).
query I
SELECT id FROM docs
ORDER BY ts_rank(to_tsvector('simple', body), to_tsquery('simple', 'quick | dog')) DESC, id
----
3
1
2

# A non-matching document ranks 0.
query R
SELECT ts_rank(to_tsvector('simple', 'cat'), to_tsquery('simple', 'fox'))
----
0.000

# The three-argument form takes a normalization bit-mask (2 = divide by document length):
# 0.09910322/2 = 0.04955161 (PG16 value; the harness rounds to 3dp).
query R
SELECT ts_rank(to_tsvector('simple', 'a b'), to_tsquery('simple', 'a & b'), 2)
----
0.050
