# p9_window/frames_and_value_functions — window breadth beyond ranking/LAG/LEAD (-46):
# running + framed aggregates (ROWS frames), partitioned MIN/MAX, the value functions
# FIRST_VALUE / LAST_VALUE / NTH_VALUE, and the distribution functions NTILE / CUME_DIST /
# PERCENT_RANK. Every expected result is the SQL-standard answer computed by hand.

statement ok
CREATE TABLE t (id INT NOT NULL, grp TEXT, v INT)

statement ok
INSERT INTO t VALUES (1, 'a', 10), (2, 'a', 20), (3, 'a', 30), (4, 'b', 40), (5, 'b', 50)

# --- running SUM via the default frame (ORDER BY, no PARTITION): unique keys ⇒ row-by-row total ---
query II
SELECT id, SUM(v) OVER (ORDER BY id) FROM t ORDER BY id
----
1 10
2 30
3 60
4 100
5 150

# --- explicit ROWS UNBOUNDED PRECEDING .. CURRENT ROW equals the running total above ---
query II
SELECT id, SUM(v) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) FROM t ORDER BY id
----
1 10
2 30
3 60
4 100
5 150

# --- moving window: ROWS BETWEEN 1 PRECEDING AND CURRENT ROW (current + previous row) ---
query II
SELECT id, SUM(v) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND CURRENT ROW) FROM t ORDER BY id
----
1 10
2 30
3 50
4 70
5 90

# --- running AVG over the same frame: running sum / running count (10, 15, 20, 25, 30) ---
query IT
SELECT id, AVG(v) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) FROM t ORDER BY id
----
1 10.0000000000000000
2 15.0000000000000000
3 20.0000000000000000
4 25.0000000000000000
5 30.0000000000000000

# --- running SUM resets per partition (PARTITION BY grp ORDER BY id, default frame) ---
query TII
SELECT grp, id, SUM(v) OVER (PARTITION BY grp ORDER BY id) FROM t ORDER BY id
----
a 1 10
a 2 30
a 3 60
b 4 40
b 5 90

# --- partitioned MIN / MAX over the whole partition (no ORDER BY ⇒ whole-partition frame) ---
query TIII
SELECT grp, id, MIN(v) OVER (PARTITION BY grp), MAX(v) OVER (PARTITION BY grp) FROM t ORDER BY id
----
a 1 10 30
a 2 10 30
a 3 10 30
b 4 40 50
b 5 40 50

# --- FIRST_VALUE (default frame) + LAST_VALUE over the full partition frame ---
# LAST_VALUE needs an explicit frame to UNBOUNDED FOLLOWING to read the partition's last row
# (the SQL-standard default frame ends at CURRENT ROW).
query TIII
SELECT grp, id,
       FIRST_VALUE(v) OVER (PARTITION BY grp ORDER BY id),
       LAST_VALUE(v) OVER (PARTITION BY grp ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
FROM t ORDER BY id
----
a 1 10 30
a 2 10 30
a 3 10 30
b 4 40 50
b 5 40 50

# --- NTH_VALUE(v, 2) over the full frame: the 2nd row by id (v = 20) on every row ---
query II
SELECT id, NTH_VALUE(v, 2) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) FROM t ORDER BY id
----
1 20
2 20
3 20
4 20
5 20

# --- NTILE(2) over 5 rows: buckets of size 3 then 2 (the first len%n buckets get the extra row) ---
query II
SELECT id, NTILE(2) OVER (ORDER BY id) FROM t ORDER BY id
----
1 1
2 1
3 1
4 2
5 2

# --- NTILE(3) over 5 rows: sizes 2, 2, 1 ---
query II
SELECT id, NTILE(3) OVER (ORDER BY id) FROM t ORDER BY id
----
1 1
2 1
3 2
4 2
5 3

# --- CUME_DIST / PERCENT_RANK with a tie: peers share the same value ---
statement ok
CREATE TABLE g (grade TEXT, score INT)

statement ok
INSERT INTO g VALUES ('a', 10), ('b', 20), ('c', 20), ('d', 40)

# CUME_DIST   = (rows up to and including the peer group) / N : 1/4, 3/4, 3/4, 4/4
# PERCENT_RANK= (peer-group rank - 1) / (N - 1)               : 0/3, 1/3, 1/3, 3/3
query TIRR
SELECT grade, score,
       CUME_DIST() OVER (ORDER BY score),
       PERCENT_RANK() OVER (ORDER BY score)
FROM g ORDER BY score, grade
----
a 10 0.250 0.000
b 20 0.750 0.333
c 20 0.750 0.333
d 40 1.000 1.000

# --- Window function nested inside an expression (-46) ---
# A window call wrapped in CAST/ROUND/arithmetic is extracted and the outer expression evaluates.
query II
SELECT id, CAST(AVG(v) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS INT) FROM t ORDER BY id
----
1 10
2 15
3 20
4 25
5 30

# Arithmetic on a window result.
query II
SELECT id, (SUM(v) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)) + 1 FROM t ORDER BY id
----
1 11
2 31
3 61
4 101
5 151

# Two windows combined in one expression.
query II
SELECT id, ROW_NUMBER() OVER (ORDER BY id) + RANK() OVER (ORDER BY v) FROM t ORDER BY id
----
1 2
2 4
3 6
4 8
5 10

# --- GROUPS frame: the offset counts peer groups (rows sharing the ORDER BY value), not physical
# rows (Q-RANGE-OFFSET-FRAME). A RANGE value offset stays unsupported. ---
statement ok
CREATE TABLE gw (grp INT, x INT)

statement ok
INSERT INTO gw VALUES (1, 10), (1, 20), (2, 30), (2, 40), (3, 50)

# GROUPS BETWEEN 1 PRECEDING AND 1 FOLLOWING: the current peer group plus one group on each side.
query III
SELECT grp, x, SUM(x) OVER (ORDER BY grp GROUPS BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM gw ORDER BY grp, x
----
1  10  100
1  20  100
2  30  150
2  40  150
3  50  120

# GROUPS BETWEEN CURRENT ROW AND 1 FOLLOWING: the current group and the next one.
query III
SELECT grp, x, SUM(x) OVER (ORDER BY grp GROUPS BETWEEN CURRENT ROW AND 1 FOLLOWING) FROM gw ORDER BY grp, x
----
1  10  100
1  20  100
2  30  120
2  40  120
3  50  50

# GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW: counts rows in the previous group and the current one.
query III
SELECT grp, x, COUNT(*) OVER (ORDER BY grp GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW) FROM gw ORDER BY grp, x
----
1  10  2
1  20  2
2  30  4
2  40  4
3  50  3

# Over consecutive integer groups (no gaps) a RANGE value offset coincides with the GROUPS result.
query III
SELECT grp, x, SUM(x) OVER (ORDER BY grp RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM gw ORDER BY grp, x
----
1  10  100
1  20  100
2  30  150
2  40  150
3  50  120

# --- RANGE value-offset frames: the frame is by ORDER BY VALUE, not row position, so a gap in the
# values matters (Q-RANGE-OFFSET-FRAME). v1: single ASC integer/temporal ordering column. ---
statement ok
CREATE TABLE rw (id INT, v INT)

statement ok
INSERT INTO rw VALUES (1, 10), (2, 20), (3, 30), (5, 40), (6, 50)

# RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING: rows with id in [cur-1, cur+1]. The gap at id=4 means
# id=3's frame is {2,3} and id=5's is {5,6} (4 is absent) — a ROWS frame would not skip the gap.
query II
SELECT id, SUM(v) OVER (ORDER BY id RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM rw ORDER BY id
----
1  30
2  60
3  50
5  90
6  90

# RANGE BETWEEN 2 PRECEDING AND CURRENT ROW (CURRENT ROW is value-peer-aware).
query II
SELECT id, SUM(v) OVER (ORDER BY id RANGE BETWEEN 2 PRECEDING AND CURRENT ROW) FROM rw ORDER BY id
----
1  10
2  30
3  60
5  70
6  90

# RANGE BETWEEN CURRENT ROW AND 2 FOLLOWING.
query II
SELECT id, SUM(v) OVER (ORDER BY id RANGE BETWEEN CURRENT ROW AND 2 FOLLOWING) FROM rw ORDER BY id
----
1  60
2  50
3  70
5  90
6  50

# Peer groups (duplicate ordering values): CURRENT ROW spans the whole peer group.
statement ok
CREATE TABLE pr (id INT, v INT)

statement ok
INSERT INTO pr VALUES (1, 10), (1, 20), (2, 30), (2, 40)

query II
SELECT id, SUM(v) OVER (ORDER BY id RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) FROM pr ORDER BY id, v
----
1  30
1  30
2  100
2  100

# Temporal ordering with an INTERVAL offset: a calendar-aware value range.
statement ok
CREATE TABLE dt (d DATE, v INT)

statement ok
INSERT INTO dt VALUES (DATE '2024-01-01', 10), (DATE '2024-01-02', 20), (DATE '2024-01-04', 30)

query TI
SELECT d::text, SUM(v) OVER (ORDER BY d RANGE BETWEEN INTERVAL '1 day' PRECEDING AND INTERVAL '1 day' FOLLOWING) FROM dt ORDER BY d
----
2024-01-01  30
2024-01-02  30
2024-01-04  30

# A NULL ordering value frames only its peers (the NULL rows); a non-NULL row excludes NULLs.
statement ok
CREATE TABLE nn (id INT, v INT)

statement ok
INSERT INTO nn VALUES (1, 10), (NULL, 20), (3, 30)

query II
SELECT COALESCE(id, -1), SUM(v) OVER (ORDER BY id RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM nn ORDER BY id NULLS LAST
----
1   10
3   30
-1  20

# A float ordering column with a RANGE offset is still rejected (loud, not silent-wrong).
statement ok
CREATE TABLE fr (f FLOAT, v INT)

statement error
SELECT SUM(v) OVER (ORDER BY f RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM fr

# --- RANGE value-offset over a DESC ordering: the frame is still by ORDER BY VALUE, but "preceding"
# rows now have LARGER keys, so the boundary direction reverses (Q-RANGE-DESC-FRAME). Reuses rw
# (id,v) = (1,10)(2,20)(3,30)(5,40)(6,50) with the gap at id=4. ---

# DESC, RANGE BETWEEN 2 PRECEDING AND CURRENT ROW: PRECEDING rows are larger, so the frame is the
# rows with id in [cur, cur+2]. id=1 -> {1,2,3}=60; id=2 -> {2,3}=50; id=3 -> {3,5}=70 (4 absent);
# id=5 -> {5,6}=90; id=6 -> {6}=50.
query II
SELECT id, SUM(v) OVER (ORDER BY id DESC RANGE BETWEEN 2 PRECEDING AND CURRENT ROW) FROM rw ORDER BY id
----
1  60
2  50
3  70
5  90
6  50

# DESC, RANGE BETWEEN CURRENT ROW AND 2 FOLLOWING: FOLLOWING rows are smaller, so the frame is the
# rows with id in [cur-2, cur]. id=1 -> {1}=10; id=2 -> {1,2}=30; id=3 -> {1,2,3}=60; id=5 ->
# {3,5}=70 (4 absent); id=6 -> {5,6}=90 (4 absent).
query II
SELECT id, SUM(v) OVER (ORDER BY id DESC RANGE BETWEEN CURRENT ROW AND 2 FOLLOWING) FROM rw ORDER BY id
----
1  10
2  30
3  60
5  70
6  90

# A symmetric DESC frame (1 PRECEDING AND 1 FOLLOWING) covers the same value window [cur-1, cur+1] as
# the ASC case, so it matches the ASC result (a sanity check that the direction reversal is symmetric).
query II
SELECT id, SUM(v) OVER (ORDER BY id DESC RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) FROM rw ORDER BY id
----
1  30
2  60
3  50
5  90
6  90
