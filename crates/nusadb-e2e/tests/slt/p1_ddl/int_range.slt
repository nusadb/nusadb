# p1_ddl/int_range — narrow integer width is enforced AND the declared type round-trips (K4/K6).
#
# SMALLINT / INT / TINYINT / MEDIUMINT are stored as a 64-bit INT, but a value outside the declared
# width is rejected at write time via a desugared range CHECK ("col" BETWEEN lo AND hi) rather than
# silently stored (the K4/K6 silent-overflow bug). BIGINT spans the full i64 and needs no check.
# NULL is always allowed (a CHECK is not violated by NULL). SMALLINT/BIGINT additionally keep their
# declared type so it round-trips in SHOW COLUMNS / information_schema (no longer collapsed to INT).

statement ok
CREATE TABLE t (id INT NOT NULL, s SMALLINT, i INT, b BIGINT)

# --- SMALLINT: [-32768, 32767] ---
# At the bounds — accepted.
statement ok
INSERT INTO t (id, s) VALUES (1, 32767)

statement ok
INSERT INTO t (id, s) VALUES (2, -32768)

# Just past the bounds — rejected, not silently wrapped/stored.
statement error
INSERT INTO t (id, s) VALUES (3, 32768)

statement error
INSERT INTO t (id, s) VALUES (4, -32769)

# NULL is allowed.
statement ok
INSERT INTO t (id, s) VALUES (5, NULL)

# --- INT: [-2147483648, 2147483647] ---
statement ok
INSERT INTO t (id, i) VALUES (6, 2147483647)

statement error
INSERT INTO t (id, i) VALUES (7, 2147483648)

# --- BIGINT: the full 64-bit range is accepted ---
statement ok
INSERT INTO t (id, b) VALUES (8, 9223372036854775807)

# --- UPDATE that would exceed the declared width is also rejected ---
statement error
UPDATE t SET s = 40000 WHERE id = 1

# Only the rows that satisfied the width constraint are present (ids 1, 2, 5, 6, 8).
query I
SELECT count(*) FROM t
----
5

# The in-range values survived intact (no silent wrap).
query II
SELECT id, s FROM t WHERE s IS NOT NULL ORDER BY id
----
1 32767
2 -32768

# Declared-type fidelity (K4/K6): SMALLINT and BIGINT round-trip in SHOW COLUMNS instead of
# collapsing to INT; plain INT still renders INT.
query TTI
SHOW COLUMNS FROM t
----
id INT 0
s SMALLINT 1
i INT 1
b BIGINT 1

# information_schema.columns reports the standard SQL data_type names (smallint / integer / bigint).
query TT
SELECT column_name, data_type FROM information_schema.columns
WHERE table_name = 't' ORDER BY ordinal_position
----
id integer
s smallint
i integer
b bigint
