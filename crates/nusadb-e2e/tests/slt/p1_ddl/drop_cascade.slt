# Q-DROP-CASCADE (QA Q50): DROP TABLE ... CASCADE drops the FOREIGN KEYs on other tables that
# reference it — the standard's semantics: the dependent CONSTRAINT goes, never the child table
# or its rows. Plain DROP still refuses (RESTRICT).

statement ok
CREATE TABLE parent (id INT PRIMARY KEY)

statement ok
CREATE TABLE child (id INT PRIMARY KEY, pid INT REFERENCES parent (id))

statement ok
INSERT INTO parent VALUES (1)

statement ok
INSERT INTO child VALUES (10, 1)

# RESTRICT (the default): the referencing FK blocks the drop.
statement error
DROP TABLE parent

statement ok
DROP TABLE parent CASCADE

# The child table and its rows survive; the FK is gone, so a formerly-dangling value inserts.
query II
SELECT id, pid FROM child
----
10 1

statement ok
INSERT INTO child VALUES (11, 999)

statement ok
DROP TABLE child
