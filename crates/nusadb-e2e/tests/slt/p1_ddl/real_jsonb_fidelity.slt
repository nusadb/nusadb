# p1_ddl/real_jsonb_fidelity — REAL and JSONB round-trip their declared type.
#
# REAL is stored as the same 64-bit double as FLOAT (DOUBLE PRECISION), and JSONB as the same
# canonical text as JSON, but each keeps its declared type so it round-trips in SHOW COLUMNS and
# information_schema instead of collapsing to FLOAT / JSON.

statement ok
CREATE TABLE t (id INT NOT NULL, r REAL, d DOUBLE PRECISION, j JSON, jb JSONB)

# Declared-type fidelity: REAL/JSONB render as themselves; DOUBLE PRECISION renders FLOAT, JSON JSON.
query TTI
SHOW COLUMNS FROM t
----
id INT 0
r REAL 1
d FLOAT 1
j JSON 1
jb JSONB 1

# information_schema.columns reports the standard SQL data_type names.
query TT
SELECT column_name, data_type FROM information_schema.columns
WHERE table_name = 't' ORDER BY ordinal_position
----
id integer
r real
d double precision
j json
jb jsonb

# Values round-trip correctly: REAL stores a full double; JSONB normalizes to canonical (sorted) text
# exactly like JSON.
statement ok
INSERT INTO t VALUES (1, 1.5, 2.25, '{"b": 2, "a": 1}', '{ "y": 9, "x": 8 }')

query RR
SELECT r, d FROM t WHERE id = 1
----
1.500 2.250

query TT
SELECT j, jb FROM t WHERE id = 1
----
{"a": 1, "b": 2} {"x": 8, "y": 9}
