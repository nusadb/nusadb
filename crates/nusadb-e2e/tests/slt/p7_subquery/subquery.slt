# p7_subquery/subquery — subquery breadth: scalar, IN/NOT IN,
# EXISTS/NOT EXISTS, quantified ANY/ALL, and correlation, each with the NULL- and
# empty-set edge cases that distinguish a correct 3VL implementation.

statement ok
CREATE TABLE dept (d_id INT NOT NULL, d_name TEXT)

statement ok
INSERT INTO dept VALUES (1, 'eng'), (2, 'ops'), (3, 'empty')

statement ok
CREATE TABLE emp (e_id INT NOT NULL, e_dept INT, e_salary INT)

statement ok
INSERT INTO emp VALUES (10, 1, 100), (11, 1, 150), (12, 2, 120), (13, NULL, 90)

# --- scalar subquery ---
query I
SELECT e_id FROM emp WHERE e_salary = (SELECT MAX(e_salary) FROM emp)
----
11

# scalar subquery over an empty set yields NULL -> comparison is UNKNOWN -> no rows
query I
SELECT e_id FROM emp WHERE e_salary = (SELECT MAX(e_salary) FROM emp WHERE e_dept = 99)
----

# --- IN / NOT IN ---
query I
SELECT e_id FROM emp WHERE e_dept IN (SELECT d_id FROM dept WHERE d_name = 'eng') ORDER BY e_id
----
10
11

# NOT IN over a list containing no match: NULL e_dept row must NOT appear (NULL IN ... = UNKNOWN)
query I
SELECT e_id FROM emp WHERE e_dept NOT IN (SELECT d_id FROM dept WHERE d_name = 'ops') ORDER BY e_id
----
10
11

# IN over an empty subquery result -> FALSE for every row
query I
SELECT e_id FROM emp WHERE e_dept IN (SELECT d_id FROM dept WHERE d_name = 'nope')
----

# --- EXISTS / NOT EXISTS (correlated) ---
query T
SELECT d_name FROM dept d WHERE EXISTS (SELECT e_id FROM emp e WHERE e.e_dept = d.d_id) ORDER BY d_name
----
eng
ops

query T
SELECT d_name FROM dept d WHERE NOT EXISTS (SELECT e_id FROM emp e WHERE e.e_dept = d.d_id) ORDER BY d_name
----
empty

# --- quantified ANY / ALL ---
# > ANY: salary above the minimum of dept 1 (100) -> 11, 12
query I
SELECT e_id FROM emp WHERE e_salary > ANY ((SELECT e_salary FROM emp WHERE e_dept = 1)) ORDER BY e_id
----
11
12

# > ALL: salary above every dept-1 salary (max 150) -> none
query I
SELECT e_id FROM emp WHERE e_salary > ALL ((SELECT e_salary FROM emp WHERE e_dept = 1))
----

# > ALL over an empty set is TRUE for every row
query I
SELECT e_id FROM emp WHERE e_salary > ALL ((SELECT e_salary FROM emp WHERE e_dept = 99)) ORDER BY e_id
----
10
11
12
13

# > ANY over an empty set is FALSE for every row
query I
SELECT e_id FROM emp WHERE e_salary > ANY ((SELECT e_salary FROM emp WHERE e_dept = 99))
----

# --- correlated scalar in the projection ---
query II
SELECT d_id, (SELECT COUNT(*) FROM emp e WHERE e.e_dept = d.d_id) FROM dept d ORDER BY d_id
----
1 2
2 1
3 0
