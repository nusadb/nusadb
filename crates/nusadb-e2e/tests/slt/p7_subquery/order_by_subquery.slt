# p7_subquery/order_by_subquery — subqueries in ORDER BY.
#
# A correlated subquery in an ORDER BY key is evaluated per row (the common, useful case); an
# uncorrelated one is pre-resolved once to a constant key.

statement ok
CREATE TABLE t (id INT, name TEXT)

statement ok
INSERT INTO t VALUES (1, 'a'), (2, 'b'), (3, 'c')

statement ok
CREATE TABLE votes (tid INT)

statement ok
INSERT INTO votes VALUES (1), (1), (3)

# Order by a correlated vote count, descending (id 1 has 2 votes, id 3 has 1, id 2 has 0).
query IT
SELECT id, name FROM t ORDER BY (SELECT COUNT(*) FROM votes WHERE votes.tid = t.id) DESC, id
----
1 a
3 c
2 b

# Same, ascending.
query I
SELECT id FROM t ORDER BY (SELECT COUNT(*) FROM votes WHERE votes.tid = t.id) ASC, id
----
2
3
1

# An uncorrelated scalar subquery is a constant key, so the row order is decided by the tiebreak.
query I
SELECT id FROM t ORDER BY (SELECT MAX(tid) FROM votes), id
----
1
2
3

# A correlated subquery key combined with an expression (id1=2+1, id2=0+2, id3=1+3).
query I
SELECT id FROM t ORDER BY (SELECT COUNT(*) FROM votes WHERE votes.tid = t.id) + id DESC
----
3
1
2
