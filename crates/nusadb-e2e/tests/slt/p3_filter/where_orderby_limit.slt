# p3_filter/where_orderby_limit — predicates, sorting, and row caps.

statement ok
CREATE TABLE nums (id INT NOT NULL, v INT, kind TEXT)

statement ok
INSERT INTO nums VALUES
  (1, 10, 'a'),
  (2, 20, 'b'),
  (3, 30, 'a'),
  (4, 40, 'b'),
  (5, 50, 'a')

# WHERE with =
query I rowsort
SELECT id FROM nums WHERE v = 30
----
3

# WHERE with comparison
query I rowsort
SELECT id FROM nums WHERE v > 25
----
3
4
5

# WHERE with AND
query I rowsort
SELECT id FROM nums WHERE v > 15 AND kind = 'a'
----
3
5

# WHERE with OR
query I rowsort
SELECT id FROM nums WHERE v < 15 OR v > 45
----
1
5

# IN list
query I rowsort
SELECT id FROM nums WHERE id IN (1, 3, 99)
----
1
3

# NOT IN
query I rowsort
SELECT id FROM nums WHERE id NOT IN (1, 3, 5)
----
2
4

# BETWEEN (inclusive)
query I rowsort
SELECT id FROM nums WHERE v BETWEEN 20 AND 40
----
2
3
4

# LIKE pattern
query I rowsort
SELECT id FROM nums WHERE kind LIKE 'a'
----
1
3
5

# ORDER BY ASC (default)
query II nosort
SELECT id, v FROM nums ORDER BY v
----
1  10
2  20
3  30
4  40
5  50

# ORDER BY DESC
query II nosort
SELECT id, v FROM nums ORDER BY v DESC
----
5  50
4  40
3  30
2  20
1  10

# LIMIT after ORDER BY
query I nosort
SELECT id FROM nums ORDER BY v DESC LIMIT 3
----
5
4
3

# LIMIT 0 returns no rows
query I
SELECT id FROM nums LIMIT 0
----

# Multi-key ORDER BY
query TI nosort
SELECT kind, id FROM nums ORDER BY kind ASC, id DESC
----
a  5
a  3
a  1
b  4
b  2
