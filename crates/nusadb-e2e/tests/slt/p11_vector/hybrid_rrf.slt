# Hybrid search via Reciprocal Rank Fusion: rrf_score(rank [, k]) = 1/(k + rank),
# k defaulting to 60 (the standard constant). Each rank comes from a RANK() window over one
# ranked list; summing the contributions fuses the lists.

# rrf_score(1) = 1/61 = 0.01639... (the query type rounds to 3dp).
query R
SELECT rrf_score(1)
----
0.016

# Explicit k: rrf_score(1, 0) = 1/1.
query R
SELECT rrf_score(1, 0)
----
1.000

# Contributions decay with rank.
query R
SELECT rrf_score(4, 6)
----
0.100

# Out-of-domain inputs are loud errors, not silent inf/NaN: RANK() starts at 1.
statement error
SELECT rrf_score(0)

statement error
SELECT rrf_score(1, -1)

# NULL propagates.
query I
SELECT rrf_score(NULL) IS NULL
----
1

# --- Hybrid fusion end-to-end: FTS ranking + vector ranking fused with RRF ---

statement ok
CREATE TABLE hybrid_docs (id INT, body TEXT, embedding VECTOR(3))

statement ok
INSERT INTO hybrid_docs VALUES
  (1, 'the quick brown fox', '[1,0,0]'),
  (2, 'lazy dogs sleep', '[0.9,0.1,0]'),
  (3, 'foxes jump over dogs', '[0,1,0]')

# Vector list: doc 1 is closest to [1,0,0], then 2, then 3. FTS list for 'fox': docs 1 and 3
# tie (single occurrence each, both RANK 1). Fused with k=60:
#   doc 1 = 1/61 + 1/61 = 0.0328,  doc 3 = 1/63 + 1/61 = 0.0323,  doc 2 = 1/62 = 0.0161
# so the hybrid order is 1, 3, 2 — doc 3 beats doc 2 only because of its FTS contribution.
query I
SELECT id FROM (
  SELECT id, SUM(contribution) AS fused FROM (
    SELECT id, rrf_score(RANK() OVER (ORDER BY embedding <=> '[1,0,0]'::VECTOR(3))) AS contribution
    FROM hybrid_docs
    UNION ALL
    SELECT id, rrf_score(RANK() OVER (ORDER BY ts_rank(to_tsvector('english', body), to_tsquery('english', 'fox')) DESC)) AS contribution
    FROM hybrid_docs
    WHERE to_tsvector('english', body) @@ to_tsquery('english', 'fox')
  ) AS contributions
  GROUP BY id
) AS fusion
ORDER BY fused DESC, id
----
1
3
2

statement ok
DROP TABLE hybrid_docs
