# p11_vector/vector — VECTOR(n) type + distance operator/functions.
# Covers: VECTOR(n) catalog type, `[..]` text-literal storage (vector form), canonical display,
# CAST text<->vector, dimension enforcement, the `<=>` cosine-distance operator, and the
# l2_distance / cosine_distance / inner_product functions (brute-force KNN via ORDER BY ... LIMIT).

statement ok
CREATE TABLE items (id INT NOT NULL, embedding VECTOR(3))

# A bare `[..]` text literal assigns into a VECTOR column (parsed + dimension-checked at encode).
statement ok
INSERT INTO items VALUES (1, '[1,0,0]'), (2, '[0,1,0]'), (3, '[1,1,0]')

# Canonical `[..]` vector display.
query IT
SELECT id, embedding FROM items ORDER BY id
----
1  [1,0,0]
2  [0,1,0]
3  [1,1,0]

# Wrong dimension is rejected (the column is VECTOR(3)).
statement error
INSERT INTO items VALUES (4, '[1,2,3,4]')

# Malformed literal is rejected.
statement error
INSERT INTO items VALUES (4, '[1,oops,3]')

# CAST text -> vector round-trips through the canonical form.
query T
SELECT CAST('[7,8,9]' AS VECTOR(3))
----
[7,8,9]

# CAST vector -> text yields the `[..]` form.
query T
SELECT CAST(embedding AS TEXT) FROM items WHERE id = 3
----
[1,1,0]

# `<=>` cosine distance to the query vector, with the `::` cast form.
query R
SELECT embedding <=> '[1,0,0]'::VECTOR(3) FROM items ORDER BY id
----
0.000
1.000
0.293

# Brute-force nearest-neighbour: ORDER BY cosine distance ASC, closest first.
query I
SELECT id FROM items ORDER BY embedding <=> CAST('[1,0,0]' AS VECTOR(3))
----
1
3
2

# l2_distance (Euclidean) to [1,0,0].
query R
SELECT l2_distance(embedding, '[1,0,0]'::VECTOR(3)) FROM items ORDER BY id
----
0.000
1.414
1.000

# cosine_distance matches the `<=>` operator.
query R
SELECT cosine_distance(embedding, '[1,0,0]'::VECTOR(3)) FROM items ORDER BY id
----
0.000
1.000
0.293

# inner_product is the negative dot product (smaller = closer); query vector [2,3,0].
query R
SELECT inner_product(embedding, '[2,3,0]'::VECTOR(3)) FROM items ORDER BY id
----
-2.000
-3.000
-5.000

# A NULL operand propagates NULL through the operator.
query T
SELECT NULL <=> '[1,0,0]'::VECTOR(3)
----
NULL

# Comparing different dimensions is a type error.
statement error
SELECT embedding <=> '[1,0]'::VECTOR(2) FROM items
