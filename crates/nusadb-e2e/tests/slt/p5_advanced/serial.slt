# p5_advanced/serial — SERIAL / BIGSERIAL auto-increment columns.
#
# A SERIAL column is an INT backed by a per-column sequence; an omitted value gets the next sequence
# value. Covers: sequential fill, multi-row insert, explicit override, BIGSERIAL, DEFAULT VALUES,
# and DROP-resets-the-sequence.

statement ok
CREATE TABLE s (id SERIAL, name TEXT)

statement ok
INSERT INTO s (name) VALUES ('a')

statement ok
INSERT INTO s (name) VALUES ('b')

statement ok
INSERT INTO s (name) VALUES ('c')

query IT
SELECT id, name FROM s ORDER BY id
----
1 a
2 b
3 c

# A multi-row INSERT advances the sequence once per row.
statement ok
INSERT INTO s (name) VALUES ('d'), ('e')

query I
SELECT id FROM s WHERE name = 'e'
----
5

# An explicit id is honored (the sequence is not consulted for a supplied value).
statement ok
INSERT INTO s (id, name) VALUES (100, 'big')

query I
SELECT id FROM s WHERE name = 'big'
----
100

# --- An explicit value advances the sequence so a later auto value cannot collide (deep-gate #9b) ---
statement ok
CREATE TABLE adv (id SERIAL PRIMARY KEY, v INT)

statement ok
INSERT INTO adv (id, v) VALUES (1, 10), (5, 50)

# The next auto-generated id must skip past the largest explicit value (5), not restart at 1 and
# collide with the existing PRIMARY KEY.
statement ok
INSERT INTO adv (v) VALUES (60)

query II
SELECT id, v FROM adv ORDER BY id
----
1 10
5 50
6 60

# --- BIGSERIAL behaves the same ---
statement ok
CREATE TABLE b (id BIGSERIAL, v INT)

statement ok
INSERT INTO b (v) VALUES (10)

statement ok
INSERT INTO b (v) VALUES (20)

query II
SELECT id, v FROM b ORDER BY id
----
1 10
2 20

# --- INSERT ... DEFAULT VALUES fills the serial ---
statement ok
CREATE TABLE d (id SERIAL)

statement ok
INSERT INTO d DEFAULT VALUES

statement ok
INSERT INTO d DEFAULT VALUES

query I
SELECT id FROM d ORDER BY id
----
1
2

# --- A SERIAL column may not also carry an explicit DEFAULT ---
statement error
CREATE TABLE bad (id SERIAL DEFAULT 5)

# --- DROP + recreate resets the backing sequence ---
statement ok
DROP TABLE s

statement ok
CREATE TABLE s (id SERIAL, name TEXT)

statement ok
INSERT INTO s (name) VALUES ('fresh')

query I
SELECT id FROM s WHERE name = 'fresh'
----
1

# --- SERIAL fills under INSERT ... ON CONFLICT DO UPDATE (insert path) ---
statement ok
CREATE TABLE su (id SERIAL, k INT UNIQUE, v INT)

statement ok
INSERT INTO su (k, v) VALUES (1, 10) ON CONFLICT (k) DO UPDATE SET v = 999

query II
SELECT id, v FROM su WHERE k = 1
----
1 10

# An explicit serial value through the upsert insert path also advances the sequence (deep-gate #9b).
statement ok
INSERT INTO su (id, k, v) VALUES (7, 2, 20) ON CONFLICT (k) DO UPDATE SET v = 999

statement ok
INSERT INTO su (k, v) VALUES (3, 30) ON CONFLICT (k) DO UPDATE SET v = 999

query I
SELECT id FROM su WHERE k = 3
----
8

# --- GENERATED { ALWAYS | BY DEFAULT } AS IDENTITY: SQL-standard auto-increment ---
statement ok
CREATE TABLE ident (id INT GENERATED ALWAYS AS IDENTITY, name TEXT)

statement ok
INSERT INTO ident (name) VALUES ('x')

statement ok
INSERT INTO ident (name) VALUES ('y')

query IT
SELECT id, name FROM ident ORDER BY id
----
1 x
2 y

# GENERATED ALWAYS rejects an explicit value — the column is always system-generated (#9a).
statement error
INSERT INTO ident (id, name) VALUES (100, 'z')

statement ok
CREATE TABLE ident2 (id BIGINT GENERATED BY DEFAULT AS IDENTITY, v INT)

statement ok
INSERT INTO ident2 (v) VALUES (10)

query II
SELECT id, v FROM ident2 WHERE v = 10
----
1 10

# GENERATED BY DEFAULT, in contrast, accepts an explicit value (like SERIAL) (#9a).
statement ok
INSERT INTO ident2 (id, v) VALUES (50, 20)

query I
SELECT id FROM ident2 WHERE v = 20
----
50
