# p5_advanced/column_default — column DEFAULT.
#
# A column omitted from an INSERT is filled by its DEFAULT expression instead of NULL.
# Covers: constant defaults, expression defaults, explicit-value override, NOT NULL + default,
# INSERT ... SELECT, subquery rejection, and DROP-clears-defaults.

statement ok
CREATE TABLE t (id INT, qty INT DEFAULT 1, label TEXT DEFAULT 'none', total INT DEFAULT 2 + 3)

# Omitting the defaulted columns fills them from their DEFAULT.
statement ok
INSERT INTO t (id) VALUES (10)

query IITI
SELECT id, qty, label, total FROM t ORDER BY id
----
10 1 none 5

# An explicit value overrides the default; a column with no default is still NULL.
statement ok
INSERT INTO t (id, qty, label) VALUES (20, 99, 'set')

query IITI
SELECT id, qty, label, total FROM t ORDER BY id
----
10 1 none 5
20 99 set 5

# A NULL passed explicitly stays NULL (the default only fills an *omitted* column).
statement ok
INSERT INTO t (id, label) VALUES (30, NULL)

query T
SELECT label FROM t WHERE id = 30
----
NULL

# INSERT ... SELECT also applies defaults for omitted columns.
statement ok
INSERT INTO t (id) SELECT 40

query II
SELECT id, qty FROM t WHERE id = 40
----
40 1

# --- NOT NULL column with a default: omitting it is fine ---
statement ok
CREATE TABLE nn (id INT, status TEXT NOT NULL DEFAULT 'active')

statement ok
INSERT INTO nn (id) VALUES (1)

query T
SELECT status FROM nn WHERE id = 1
----
active

# --- A subquery default is rejected at CREATE ---
statement error
CREATE TABLE bad (a INT DEFAULT (SELECT 1))

# --- DROP clears the table's defaults: a recreated table does not inherit them ---
statement ok
DROP TABLE t

statement ok
CREATE TABLE t (id INT, qty INT)

statement ok
INSERT INTO t (id) VALUES (1)

# qty has no default now, so it is NULL (not the old DEFAULT 1).
query T
SELECT CAST(qty AS TEXT) FROM t WHERE id = 1
----
NULL

# --- ALTER TABLE ... SET / DROP DEFAULT ---
statement ok
CREATE TABLE a (id INT, n INT)

# No default yet: an omitted column is NULL.
statement ok
INSERT INTO a (id) VALUES (1)

# Add a default, then a later omitting INSERT picks it up.
statement ok
ALTER TABLE a ALTER COLUMN n SET DEFAULT 42

statement ok
INSERT INTO a (id) VALUES (2)

query T
SELECT CAST(n AS TEXT) FROM a WHERE id = 1
----
NULL

query I
SELECT n FROM a WHERE id = 2
----
42

# Re-setting the default replaces the old one.
statement ok
ALTER TABLE a ALTER COLUMN n SET DEFAULT 7

statement ok
INSERT INTO a (id) VALUES (3)

query I
SELECT n FROM a WHERE id = 3
----
7

# Dropping the default goes back to NULL for omitted columns.
statement ok
ALTER TABLE a ALTER COLUMN n DROP DEFAULT

statement ok
INSERT INTO a (id) VALUES (4)

query T
SELECT CAST(n AS TEXT) FROM a WHERE id = 4
----
NULL

# A type-incompatible SET DEFAULT is rejected.
statement error
ALTER TABLE a ALTER COLUMN n SET DEFAULT 'not an int'

# --- INSERT ... DEFAULT VALUES: every column takes its DEFAULT ---
statement ok
CREATE TABLE dv (a INT DEFAULT 7, b TEXT DEFAULT 'hi', c INT)

statement ok
INSERT INTO dv DEFAULT VALUES

query IT
SELECT a, b FROM dv
----
7 hi

# A column with no default is NULL under DEFAULT VALUES.
query T
SELECT CAST(c AS TEXT) FROM dv
----
NULL

# DEFAULT VALUES on a NOT-NULL column without a default is rejected.
statement ok
CREATE TABLE dv2 (id INT NOT NULL, n INT DEFAULT 1)

statement error
INSERT INTO dv2 DEFAULT VALUES

# --- DEFAULT applies under INSERT ... ON CONFLICT DO UPDATE (insert path) ---
statement ok
CREATE TABLE up (id INT PRIMARY KEY, n INT DEFAULT 9)

# First insert: no conflict, the omitted n takes its DEFAULT.
statement ok
INSERT INTO up (id) VALUES (1) ON CONFLICT (id) DO UPDATE SET n = 100

query I
SELECT n FROM up WHERE id = 1
----
9

# Second insert conflicts on the PK, so DO UPDATE runs.
statement ok
INSERT INTO up (id) VALUES (1) ON CONFLICT (id) DO UPDATE SET n = 100

query I
SELECT n FROM up WHERE id = 1
----
100
