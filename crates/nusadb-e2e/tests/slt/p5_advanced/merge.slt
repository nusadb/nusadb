# p5_advanced/merge — MERGE INTO ... USING ... ON ... WHEN [NOT] MATCHED.
#
# Classifies each source row against the target by ON; a matched row drives the first satisfied
# WHEN MATCHED (UPDATE/DELETE), an unmatched row the first WHEN NOT MATCHED (INSERT). Covers: upsert,
# delete-on-match, AND-guards, the cardinality error, derived VALUES/subquery sources, and the
# LATERAL-source rejection.

statement ok
CREATE TABLE target (id INT PRIMARY KEY, val INT)

statement ok
INSERT INTO target VALUES (1, 10), (2, 20), (3, 30)

statement ok
CREATE TABLE src (id INT, val INT)

statement ok
INSERT INTO src VALUES (2, 200), (4, 400)

# Classic upsert: matched id 2 updates, unmatched id 4 inserts.
statement ok
MERGE INTO target USING src ON target.id = src.id
WHEN MATCHED THEN UPDATE SET val = src.val
WHEN NOT MATCHED THEN INSERT (id, val) VALUES (src.id, src.val)

query II
SELECT id, val FROM target ORDER BY id
----
1 10
2 200
3 30
4 400

# Delete-on-match.
statement ok
CREATE TABLE dsrc (id INT)

statement ok
INSERT INTO dsrc VALUES (1), (3)

statement ok
MERGE INTO target USING dsrc ON target.id = dsrc.id
WHEN MATCHED THEN DELETE

query II
SELECT id, val FROM target ORDER BY id
----
2 200
4 400

# An AND-guard on the matched clause: only update when the guard holds, else (no clause) do nothing.
statement ok
CREATE TABLE bump (id INT, add INT)

statement ok
INSERT INTO bump VALUES (2, 5), (4, 0)

statement ok
MERGE INTO target USING bump ON target.id = bump.id
WHEN MATCHED AND bump.add > 0 THEN UPDATE SET val = val + bump.add

query II
SELECT id, val FROM target ORDER BY id
----
2 205
4 400

# Cardinality: a source whose two rows both match the same target row is an error.
statement ok
CREATE TABLE dup (id INT, val INT)

statement ok
INSERT INTO dup VALUES (2, 1), (2, 2)

statement error
MERGE INTO target USING dup ON target.id = dup.id
WHEN MATCHED THEN UPDATE SET val = dup.val

# The target is unchanged after the failed (rolled-back) MERGE.
query II
SELECT id, val FROM target ORDER BY id
----
2 205
4 400

# A derived VALUES source: matched id 2 updates, unmatched id 5 inserts — the same upsert as a named
# source, driven by an inline VALUES list.
statement ok
MERGE INTO target USING (VALUES (2, 1000), (5, 500)) AS s(id, v) ON target.id = s.id
WHEN MATCHED THEN UPDATE SET val = s.v
WHEN NOT MATCHED THEN INSERT (id, val) VALUES (s.id, s.v)

query II
SELECT id, val FROM target ORDER BY id
----
2 1000
4 400
5 500

# A derived subquery source: delete the matched row (id 5).
statement ok
MERGE INTO target USING (SELECT 5) AS s(id) ON target.id = s.id
WHEN MATCHED THEN DELETE

query II
SELECT id, val FROM target ORDER BY id
----
2 1000
4 400

# A LATERAL source stays unsupported.
statement error
MERGE INTO target USING LATERAL (SELECT 9 AS id) s ON target.id = s.id WHEN MATCHED THEN DELETE
